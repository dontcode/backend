{
    "name": "@dontcode2/backend",
    "version": "0.2.3",
    "description": "Public SDK for DontCode Backend. A thin, typed proxy over the v1 HTTP gateway.",
    "keywords": [
        "dontcode",
        "backend",
        "sdk",
        "byoc",
        "auth",
        "database",
        "storage"
    ],
    "homepage": "https://github.com/dontcode/backend#readme",
    "bugs": {
        "url": "https://github.com/dontcode/backend/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dontcode/backend.git"
    },
    "license": "ISC",
    "author": "dontcode",
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        },
        "./mock": {
            "types": "./dist/mock/index.d.ts",
            "import": "./dist/mock/index.js",
            "require": "./dist/mock/index.cjs",
            "default": "./dist/mock/index.js"
        },
        "./mcp": {
            "types": "./dist/mcp/index.d.ts",
            "import": "./dist/mcp/index.js",
            "require": "./dist/mcp/index.cjs",
            "default": "./dist/mcp/index.js"
        },
        "./node": {
            "types": "./dist/node.d.ts",
            "import": "./dist/node.js",
            "require": "./dist/node.cjs",
            "default": "./dist/node.js"
        }
    },
    "bin": {
        "dontcode": "dist/cli.js",
        "dontcode-mock": "dist/mock/cli.js"
    },
    "sideEffects": false,
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsup && tsc --emitDeclarationOnly",
        "test": "npm run build && node --test tests/*.test.mjs",
        "prepublishOnly": "npm run build"
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@electric-sql/pglite": "0.5.3",
        "@trivago/prettier-plugin-sort-imports": "6.0.0",
        "@types/node": "24.10.1",
        "prettier": "3.6.2",
        "prettier-plugin-tailwindcss": "0.7.1",
        "tsup": "8.5.1",
        "typescript": "5.9.3"
    },
    "optionalDependencies": {
        "@electric-sql/pglite": "^0.5.3"
    },
    "publishConfig": {
        "access": "public"
    }
}
